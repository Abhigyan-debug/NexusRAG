# Render / production tuning (512MB instance)
WEB_CONCURRENCY=1
GUNICORN_TIMEOUT=300
GUNICORN_THREADS=2
GUNICORN_PRELOAD=false

# SQLite on Render — stored under ./data (ephemeral disk)
# Leave DATABASE_URL unset or empty to use SQLite automatically.
# DATA_DIR=/tmp/nexusrag

DOC_PROCESSING_MODE=subprocess
USE_HEAVY_NLP=false
USE_LIGHTWEIGHT_EMBEDDINGS=false
SKIP_LLM_SUMMARY=false
EMBEDDING_BATCH_SIZE=16

FRONTEND_URL=https://your-frontend.onrender.com
JWT_SECRET_KEY=change-me
SECRET_KEY=change-me
GEMINI_API_KEY=your-key
