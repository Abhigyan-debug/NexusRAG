# Render / production tuning (512MB instance)
WEB_CONCURRENCY=1
GUNICORN_TIMEOUT=300
GUNICORN_THREADS=2

# Document processing: subprocess (default) | sync | thread
# subprocess = detached worker process — survives Gunicorn request lifecycle
DOC_PROCESSING_MODE=subprocess

# Memory savers for free tier (set true if still OOM)
USE_HEAVY_NLP=false
USE_LIGHTWEIGHT_EMBEDDINGS=false
SKIP_LLM_SUMMARY=false
EMBEDDING_BATCH_SIZE=16

# Database
DATABASE_URL=postgresql://user:pass@host:5432/nexusrag

# JWT
JWT_SECRET_KEY=change-me
SECRET_KEY=change-me

# Gemini
GEMINI_API_KEY=your-key

# Frontend CORS
FRONTEND_URL=https://your-frontend.onrender.com
